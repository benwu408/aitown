# LLM Configuration (any OpenAI-compatible endpoint)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
LLM_MAX_CONCURRENT_REQUESTS=5
LLM_TIMEOUT_SECONDS=30

# Simulation
TICK_DURATION_MS=2000
TICKS_PER_DAY=100
REFLECTION_INTERVAL=20
MAX_MEMORIES_PER_RETRIEVAL=15

# Server
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Database
DB_PATH=data/agentica.db
SNAPSHOT_INTERVAL=50
